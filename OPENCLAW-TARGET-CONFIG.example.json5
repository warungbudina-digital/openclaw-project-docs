{
  agents: {
    defaults: {
      workspace: "/home/node/.openclaw/workspace",
      model: {
        primary: "codex-cli/gpt-5.4",
      },
      models: {
        "codex-cli/gpt-5.4": {},
        "ollama/qwen2.5-coder:1.5b": {},
        "ollama/phi3:mini": {},
      },
      sandbox: {
        mode: "off",
        scope: "agent",
        workspaceAccess: "rw",
        browser: {
          enabled: true,
        },
      },
      heartbeat: {
        every: "2h",
        target: "none",
        directPolicy: "block",
        isolatedSession: true,
        lightContext: true,
        includeSystemPromptSection: false,
        timeoutSeconds: 45,
      },
      timeoutSeconds: 600,
      thinkingDefault: "low",
      contextTokens: 200000,
    },
    list: [
      {
        id: "main",
        default: true,
        name: "Main Assistant",
        workspace: "/home/node/.openclaw/workspace",
        model: "codex-cli/gpt-5.4",
        thinkingDefault: "low",
        sandbox: { mode: "off" },
        tools: {
          profile: "coding",
        },
      },
      {
        id: "lab",
        name: "Lab Ops",
        workspace: "/home/node/.openclaw/workspace-lab",
        model: "codex-cli/gpt-5.4",
        thinkingDefault: "low",
        sandbox: { mode: "off" },
        tools: {
          profile: "coding",
        },
      },
      {
        id: "worker",
        name: "Background Worker",
        workspace: "/home/node/.openclaw/workspace-worker",
        model: "ollama/qwen2.5-coder:1.5b",
        thinkingDefault: "minimal",
        sandbox: { mode: "off" },
        tools: {
          profile: "coding",
        },
      },
    ],
  },

  session: {
    dmScope: "per-channel-peer",
  },

  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
    auth: {
      mode: "token",
      token: { source: "env", provider: "default", id: "GATEWAY_AUTH_TOKEN" },
      rateLimit: {
        maxAttempts: 10,
        windowMs: 60000,
        lockoutMs: 300000,
      },
    },
    tailscale: {
      mode: "off",
      resetOnExit: false,
    },
    controlUi: {
      allowedOrigins: [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
      ],
    },
    nodes: {
      denyCommands: [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search",
      ],
    },
  },

  channels: {
    telegram: {
      enabled: true,
      botToken: { source: "env", provider: "default", id: "TELEGRAM_BOT_TOKEN" },
      groups: {
        "*": {
          requireMention: true,
        },
      },
    },
  },

  tools: {
    profile: "coding",
    web: {
      search: {
        provider: "ollama",
        enabled: true,
      },
    },
  },

  models: {
    mode: "merge",
    providers: {
      ollama: {
        baseUrl: "https://ollama.example.com/v1",
        api: "openai-completions",
        apiKey: { source: "env", provider: "default", id: "OLLAMA_BRIDGE_API_KEY" },
        models: [
          {
            id: "qwen2.5-coder:1.5b",
            name: "qwen2.5-coder:1.5b",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192,
          },
          {
            id: "phi3:mini",
            name: "phi3:mini",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 128000,
            maxTokens: 8192,
          },
        ],
      },
    },
  },

  auth: {
    profiles: {
      "ollama:default": {
        provider: "ollama",
        mode: "api_key",
      },
    },
  },

  plugins: {
    allow: ["telegram", "browser", "openai", "memory-core", "ollama"],
    entries: {
      telegram: { enabled: true },
      browser: { enabled: true },
      openai: { enabled: true },
      ollama: { enabled: true },
      "memory-core": { enabled: true },
    },
  },

  browser: {
    enabled: true,
    defaultProfile: "sbx1",
    profiles: {
      sbx1: {
        cdpUrl: "http://127.0.0.1:9222",
        color: "#00AA00",
        attachOnly: true,
      },
    },
  },

  hooks: {
    internal: {
      enabled: true,
      entries: {
        "boot-md": { enabled: true },
        "bootstrap-extra-files": { enabled: true },
        "command-logger": { enabled: true },
        "session-memory": { enabled: true },
      },
    },
  },
}
